@model List<SenacBuy.Web.Models.ClienteViewModel>
@{
    ViewData["Title"] = "Clientes";
}

<div class="page-header">
    <div class="page-header-left">
        <form method="get" class="search-box">
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" name="busca" value="@ViewBag.Busca" placeholder="Buscar clientes..." id="busca" />
        </form>
    </div>
    <a asp-action="Criar" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Novo Cliente
    </a>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">Lista de Clientes</span>
        <span class="text-muted" style="font-size:12px;">@Model.Count cliente@(Model.Count != 1 ? "s" : "")</span>
    </div>
    <div class="table-wrapper">
        @if (Model.Any())
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nome</th>
                        <th>CPF</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="text-muted">#@c.Id</td>
                            <td>
                                <div class="user-cell">
                                    <div class="user-avatar">@(c.Nome.Length > 0 ? c.Nome[0].ToString().ToUpper() : "?")</div>
                                    <div class="user-info">
                                        <div class="user-name">@c.Nome</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted">@c.CPF</td>
                            <td>
                                <div class="actions-cell">
                                    <a asp-action="Editar" asp-route-id="@c.Id" class="btn btn-sm btn-secondary">✏️ Editar</a>
                                    <form asp-action="Excluir" asp-route-id="@c.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger"
                                                data-confirm="Excluir o cliente '@c.Nome'?">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">👥</div>
                <p>@(string.IsNullOrWhiteSpace(ViewBag.Busca as string) ? "Nenhum cliente cadastrado." : "Nenhum cliente encontrado para a busca.")</p>
                <a asp-action="Criar" class="btn btn-primary" style="margin-top:12px;">Adicionar Primeiro Cliente</a>
            </div>
        }
    </div>
</div>
