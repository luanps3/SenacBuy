@model SenacBuy.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var meses        = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");
    var maxPedidos   = Model.PedidosPorMes.Any() ? Model.PedidosPorMes.Max(p => p.Total) : 1;
}

<!-- Stat Cards -->
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-icon blue">💰</div>
        <div class="stat-info">
            <div class="stat-label">Total Vendas</div>
            <div class="stat-value">@Model.TotalVendas.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">👥</div>
        <div class="stat-info">
            <div class="stat-label">Clientes</div>
            <div class="stat-value">@Model.TotalClientes</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange">📦</div>
        <div class="stat-info">
            <div class="stat-label">Produtos</div>
            <div class="stat-value">@Model.TotalProdutos</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red">🛒</div>
        <div class="stat-info">
            <div class="stat-label">Pedidos</div>
            <div class="stat-value">@Model.TotalPedidos</div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:28px;">

    <!-- Status dos pedidos -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Status dos Pedidos</span>
        </div>
        <div class="card-body">
            @{
                var total = Model.TotalPedidos == 0 ? 1 : Model.TotalPedidos;
                var pFinPct  = (int)Math.Round(Model.PedidosConcluidos  * 100.0 / total);
                var pPendPct = (int)Math.Round(Model.PedidosPendentes   * 100.0 / total);
                var pCanPct  = (int)Math.Round(Model.PedidosCancelados  * 100.0 / total);
            }
            <div style="display:flex;flex-direction:column;gap:14px;">
                <div>
                    <div style="display:flex;justify-content:space-between;font-size:13px;font-weight:600;margin-bottom:5px;">
                        <span>✅ Finalizados</span><span>@Model.PedidosConcluidos</span>
                    </div>
                    <div style="height:8px;background:#f0f4f8;border-radius:4px;overflow:hidden;">
                        <div style="height:100%;width:@(pFinPct)%;background:#22c55e;border-radius:4px;transition:width .4s;"></div>
                    </div>
                </div>
                <div>
                    <div style="display:flex;justify-content:space-between;font-size:13px;font-weight:600;margin-bottom:5px;">
                        <span>⏳ Pendentes</span><span>@Model.PedidosPendentes</span>
                    </div>
                    <div style="height:8px;background:#f0f4f8;border-radius:4px;overflow:hidden;">
                        <div style="height:100%;width:@(pPendPct)%;background:#f59e0b;border-radius:4px;transition:width .4s;"></div>
                    </div>
                </div>
                <div>
                    <div style="display:flex;justify-content:space-between;font-size:13px;font-weight:600;margin-bottom:5px;">
                        <span>❌ Cancelados</span><span>@Model.PedidosCancelados</span>
                    </div>
                    <div style="height:8px;background:#f0f4f8;border-radius:4px;overflow:hidden;">
                        <div style="height:100%;width:@(pCanPct)%;background:#ef4444;border-radius:4px;transition:width .4s;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pedidos por Mês -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Pedidos por Mês</span>
            <span class="text-muted" style="font-size:12px;">Últimos 6 meses</span>
        </div>
        <div class="card-body">
            @if (Model.PedidosPorMes.Any())
            {
                <div class="chart-bars">
                    @foreach (var item in Model.PedidosPorMes)
                    {
                        var pct = maxPedidos == 0 ? 0 : (int)Math.Round(item.Total * 100.0 / maxPedidos);
                        <div class="chart-bar-wrap">
                            <div class="chart-bar" style="height:@(pct)%;"></div>
                            <span class="chart-bar-label">@(new DateTime(item.Ano, item.Mes, 1).ToString("MMM", meses))</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state"><div class="empty-icon">📊</div><p>Sem dados disponíveis</p></div>
            }
        </div>
    </div>
</div>

<!-- Quick Links -->
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;">
    <a asp-controller="Clientes" asp-action="Criar" class="btn btn-secondary" style="justify-content:center;padding:14px;">
        ➕ Novo Cliente
    </a>
    <a asp-controller="Produtos" asp-action="Criar" class="btn btn-secondary" style="justify-content:center;padding:14px;">
        ➕ Novo Produto
    </a>
    <a asp-controller="Pedidos" asp-action="Criar" class="btn btn-secondary" style="justify-content:center;padding:14px;">
        ➕ Novo Pedido
    </a>
    <a asp-controller="Usuarios" asp-action="Criar" class="btn btn-secondary" style="justify-content:center;padding:14px;">
        ➕ Novo Usuário
    </a>
</div>
