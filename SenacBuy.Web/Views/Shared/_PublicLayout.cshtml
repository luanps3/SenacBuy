<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SenacBuy — Sistema completo de gestão de vendas, clientes, produtos e pedidos." />
    <title>@ViewData["Title"] — SenacBuy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        /* ── Reset & Base ─────────────────────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --primary:       #137fec;
            --primary-dark:  #0c5db3;
            --primary-light: #e8f3fd;
            --primary-xlight:#f0f7ff;
            --accent:        #ff6b35;
            --surface:       #ffffff;
            --bg:            #f8faff;
            --text:          #1a2333;
            --text-muted:    #64748b;
            --border:        #e2e8f0;
            --radius:        10px;
            --radius-lg:     16px;
            --radius-xl:     24px;
            --shadow-sm:     0 1px 6px rgba(19,127,236,.08);
            --shadow:        0 4px 20px rgba(19,127,236,.12);
            --shadow-lg:     0 12px 48px rgba(19,127,236,.18);
            --font:          'Manrope', system-ui, sans-serif;
            --nav-h:         68px;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: var(--font);
            color: var(--text);
            background: var(--bg);
            line-height: 1.6;
        }

        a { color: inherit; text-decoration: none; }
        img { max-width: 100%; }

        /* ── Navbar ─────────────────────────────────────────────────────────── */
        .pub-nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: var(--nav-h);
            background: rgba(255,255,255,.92);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            z-index: 1000;
            display: flex;
            align-items: center;
            padding: 0 5%;
            gap: 32px;
            box-shadow: var(--shadow-sm);
        }

        .pub-nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            font-size: 1.25rem;
            color: var(--text);
            flex-shrink: 0;
        }

        .pub-nav-logo-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            color: #fff;
            font-size: 1.1rem;
            font-weight: 800;
        }

        .pub-nav-links {
            display: flex;
            align-items: center;
            gap: 6px;
            list-style: none;
            flex: 1;
        }

        .pub-nav-links a {
            padding: 7px 14px;
            border-radius: 8px;
            font-size: .9rem;
            font-weight: 600;
            color: var(--text-muted);
            transition: background .15s, color .15s;
        }

        .pub-nav-links a:hover,
        .pub-nav-links a.active {
            background: var(--primary-light);
            color: var(--primary);
        }

        .pub-nav-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        /* Hamburger (mobile) */
        .pub-nav-toggle {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px;
            color: var(--text);
        }

        /* ── Buttons ─────────────────────────────────────────────────────────── */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 22px;
            border-radius: var(--radius);
            font-family: var(--font);
            font-size: .9rem;
            font-weight: 700;
            cursor: pointer;
            border: none;
            text-decoration: none;
            transition: all .18s ease;
            white-space: nowrap;
        }

        .btn-outline {
            background: transparent;
            color: var(--primary);
            border: 1.5px solid var(--primary);
        }
        .btn-outline:hover {
            background: var(--primary-light);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            box-shadow: 0 4px 14px rgba(19,127,236,.35);
        }
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(19,127,236,.45);
        }
        .btn-primary:active { transform: translateY(0); }

        .btn-accent {
            background: linear-gradient(135deg, var(--accent) 0%, #e05a28 100%);
            color: #fff;
            box-shadow: 0 4px 14px rgba(255,107,53,.35);
        }
        .btn-accent:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(255,107,53,.45);
        }

        .btn-lg {
            padding: 14px 32px;
            font-size: 1rem;
            border-radius: 12px;
        }

        /* ── Page wrapper ─────────────────────────────────────────────────────── */
        .pub-main {
            padding-top: var(--nav-h);
        }

        /* ── Section base ─────────────────────────────────────────────────────── */
        .pub-section {
            padding: 80px 5%;
        }

        .pub-section-label {
            font-size: .75rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--primary);
            margin-bottom: .5rem;
        }

        .pub-section-title {
            font-size: clamp(1.6rem, 3vw, 2.4rem);
            font-weight: 800;
            color: var(--text);
            line-height: 1.2;
            margin-bottom: 1rem;
        }

        .pub-section-subtitle {
            font-size: 1rem;
            color: var(--text-muted);
            max-width: 580px;
            line-height: 1.7;
        }

        .pub-section-center { text-align: center; }
        .pub-section-center .pub-section-subtitle { margin: 0 auto; }

        /* ── Hero ────────────────────────────────────────────────────────────── */
        .pub-hero {
            min-height: calc(100vh - var(--nav-h));
            display: flex;
            align-items: center;
            padding: 60px 5%;
            background: linear-gradient(135deg, #f0f7ff 0%, #e8f3fd 50%, #f8faff 100%);
            position: relative;
            overflow: hidden;
            gap: 48px;
        }

        .pub-hero::before {
            content: '';
            position: absolute;
            width: 600px; height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(19,127,236,.08) 0%, transparent 70%);
            top: -100px; right: -100px;
            pointer-events: none;
        }

        .pub-hero::after {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(19,127,236,.06) 0%, transparent 70%);
            bottom: -80px; left: 10%;
            pointer-events: none;
        }

        .pub-hero-content {
            flex: 1;
            max-width: 580px;
            z-index: 1;
        }

        .pub-hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            background: var(--primary-light);
            color: var(--primary);
            border-radius: 99px;
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .05em;
            text-transform: uppercase;
            margin-bottom: 1.25rem;
        }

        .pub-hero-badge span.dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--primary);
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50%       { opacity: .5; transform: scale(1.3); }
        }

        .pub-hero-title {
            font-size: clamp(2rem, 4vw, 3.2rem);
            font-weight: 800;
            line-height: 1.15;
            color: var(--text);
            margin-bottom: 1.25rem;
        }

        .pub-hero-title em {
            font-style: normal;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .pub-hero-subtitle {
            font-size: 1.05rem;
            color: var(--text-muted);
            line-height: 1.75;
            margin-bottom: 2rem;
        }

        .pub-hero-actions {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
        }

        .pub-hero-stats {
            display: flex;
            gap: 28px;
            margin-top: 2.5rem;
            padding-top: 2rem;
            border-top: 1px solid var(--border);
        }

        .pub-hero-stat-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--text);
        }

        .pub-hero-stat-label {
            font-size: .78rem;
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .pub-hero-visual {
            flex: 1;
            max-width: 520px;
            z-index: 1;
        }

        /* Dashboard mockup */
        .dash-mockup {
            background: #fff;
            border-radius: 20px;
            box-shadow: var(--shadow-lg);
            overflow: hidden;
            border: 1px solid var(--border);
        }

        .dash-mockup-header {
            background: #1a1d2e;
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .dash-mockup-dot {
            width: 10px; height: 10px;
            border-radius: 50%;
        }
        .dash-mockup-dot:nth-child(1) { background: #ff5f57; }
        .dash-mockup-dot:nth-child(2) { background: #febc2e; }
        .dash-mockup-dot:nth-child(3) { background: #28c840; }

        .dash-mockup-title {
            color: rgba(255,255,255,.5);
            font-size: .75rem;
            font-weight: 600;
            margin-left: 8px;
        }

        .dash-mockup-body {
            padding: 20px;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .dash-card-mini {
            background: var(--bg);
            border-radius: 10px;
            padding: 14px;
            border: 1px solid var(--border);
        }

        .dash-card-mini-label {
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .dash-card-mini-value {
            font-size: 1.3rem;
            font-weight: 800;
            color: var(--text);
        }

        .dash-card-mini-value.blue   { color: var(--primary); }
        .dash-card-mini-value.green  { color: #22c55e; }
        .dash-card-mini-value.orange { color: #f59e0b; }
        .dash-card-mini-value.red    { color: #ef4444; }

        .dash-chart-mini {
            grid-column: 1 / -1;
            background: var(--bg);
            border-radius: 10px;
            padding: 14px;
            border: 1px solid var(--border);
        }

        .dash-chart-bars {
            display: flex;
            align-items: flex-end;
            gap: 6px;
            height: 64px;
            margin-top: 8px;
        }

        .dash-chart-bar {
            flex: 1;
            background: linear-gradient(to top, var(--primary), #42a0f5);
            border-radius: 3px 3px 0 0;
            min-height: 4px;
            transition: opacity .2s;
        }

        .dash-chart-bar:hover { opacity: .8; }

        /* ── Features Grid ────────────────────────────────────────────────────── */
        .pub-features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 24px;
            margin-top: 48px;
        }

        .pub-feature-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            padding: 28px 24px;
            transition: box-shadow .2s, transform .2s;
            position: relative;
            overflow: hidden;
        }

        .pub-feature-card::after {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 3px;
            background: linear-gradient(90deg, var(--primary), var(--accent));
            opacity: 0;
            transition: opacity .2s;
        }

        .pub-feature-card:hover {
            box-shadow: var(--shadow);
            transform: translateY(-3px);
        }

        .pub-feature-card:hover::after { opacity: 1; }

        .pub-feature-icon {
            width: 52px; height: 52px;
            border-radius: 14px;
            background: var(--primary-light);
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 16px;
            font-size: 1.4rem;
        }

        .pub-feature-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 8px;
        }

        .pub-feature-desc {
            font-size: .875rem;
            color: var(--text-muted);
            line-height: 1.65;
        }

        /* ── Benefits ────────────────────────────────────────────────────────── */
        .pub-benefits {
            background: linear-gradient(135deg, #1a1d2e 0%, #0f1420 100%);
            color: #fff;
        }

        .pub-benefits .pub-section-label { color: #42a0f5; }
        .pub-benefits .pub-section-title { color: #fff; }
        .pub-benefits .pub-section-subtitle { color: rgba(255,255,255,.6); }

        .pub-benefits-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 24px;
            margin-top: 48px;
        }

        .pub-benefit-item {
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.1);
            border-radius: var(--radius-lg);
            padding: 28px 20px;
            text-align: center;
            transition: background .2s, transform .2s;
        }

        .pub-benefit-item:hover {
            background: rgba(19,127,236,.2);
            border-color: rgba(19,127,236,.4);
            transform: translateY(-2px);
        }

        .pub-benefit-icon {
            width: 56px; height: 56px;
            border-radius: 14px;
            background: rgba(255,255,255,.1);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem;
            margin: 0 auto 16px;
        }

        .pub-benefit-title {
            font-size: .95rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 8px;
        }

        .pub-benefit-desc {
            font-size: .825rem;
            color: rgba(255,255,255,.55);
            line-height: 1.6;
        }

        /* ── CTA Banner ──────────────────────────────────────────────────────── */
        .pub-cta {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            text-align: center;
            padding: 80px 5%;
        }

        .pub-cta-title {
            font-size: clamp(1.6rem, 3vw, 2.2rem);
            font-weight: 800;
            color: #fff;
            margin-bottom: .75rem;
        }

        .pub-cta-sub {
            font-size: 1rem;
            color: rgba(255,255,255,.8);
            margin-bottom: 2rem;
        }

        .pub-cta-actions {
            display: flex;
            gap: 14px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-white {
            background: #fff;
            color: var(--primary);
            font-weight: 700;
        }

        .btn-white:hover {
            background: #f0f7ff;
            transform: translateY(-1px);
        }

        .btn-ghost {
            background: rgba(255,255,255,.15);
            color: #fff;
            border: 1.5px solid rgba(255,255,255,.4);
        }

        .btn-ghost:hover {
            background: rgba(255,255,255,.25);
            transform: translateY(-1px);
        }

        /* ── Footer ──────────────────────────────────────────────────────────── */
        .pub-footer {
            background: #0f1420;
            color: rgba(255,255,255,.6);
            padding: 60px 5% 32px;
        }

        .pub-footer-top {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 40px;
            margin-bottom: 48px;
        }

        .pub-footer-brand .pub-nav-logo { margin-bottom: 1rem; }
        .pub-footer-brand p { font-size: .875rem; line-height: 1.7; max-width: 280px; }

        .pub-footer-col-title {
            font-size: .8rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: rgba(255,255,255,.9);
            margin-bottom: 16px;
        }

        .pub-footer-links {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .pub-footer-links a {
            font-size: .875rem;
            transition: color .15s;
        }

        .pub-footer-links a:hover { color: #fff; }

        .pub-footer-bottom {
            border-top: 1px solid rgba(255,255,255,.08);
            padding-top: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            font-size: .8rem;
        }

        .pub-footer-bottom-links {
            display: flex;
            gap: 20px;
        }

        .pub-footer-bottom-links a { transition: color .15s; }
        .pub-footer-bottom-links a:hover { color: #fff; }

        /* ── Mobile Menu ─────────────────────────────────────────────────────── */
        @@media (max-width: 768px) {
            .pub-nav-links {
                display: none;
                position: fixed;
                top: var(--nav-h);
                left: 0; right: 0;
                background: var(--surface);
                flex-direction: column;
                padding: 20px 5%;
                border-bottom: 1px solid var(--border);
                box-shadow: var(--shadow);
                gap: 4px;
            }

            .pub-nav-links.open { display: flex; }
            .pub-nav-actions { gap: 6px; }
            .pub-nav-toggle { display: flex; }
            .btn-lg { padding: 12px 22px; font-size: .9rem; }

            .pub-hero {
                flex-direction: column;
                min-height: auto;
                padding: 48px 5%;
                text-align: center;
            }

            .pub-hero-actions { justify-content: center; }
            .pub-hero-stats { justify-content: center; }
            .pub-hero-visual { max-width: 100%; }

            .pub-footer-top {
                grid-template-columns: 1fr 1fr;
                gap: 32px;
            }

            .pub-footer-brand {
                grid-column: 1 / -1;
            }

            .pub-footer-bottom {
                flex-direction: column;
                text-align: center;
            }
        }

        @@media (max-width: 480px) {
            .pub-footer-top { grid-template-columns: 1fr; }
            .pub-nav-actions .btn-outline { display: none; }
        }
    </style>
</head>
<body>

<!-- ── Navbar ─────────────────────────────────────────────────────────────── -->
<nav class="pub-nav">
    <a asp-controller="Home" asp-action="Index" class="pub-nav-logo">
        <div class="pub-nav-logo-icon">S</div>
        SenacBuy
    </a>

    <ul class="pub-nav-links" id="pub-nav-links">
        <li><a asp-controller="Home" asp-action="Index"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">Início</a></li>
        <li><a asp-controller="Home" asp-action="Sobre"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Sobre" ? "active" : "")">Sobre</a></li>
        <li><a asp-controller="Home" asp-action="Contato"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Contato" ? "active" : "")">Contato</a></li>
    </ul>

    <div class="pub-nav-actions">
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline">Entrar</a>
        <a asp-controller="Account" asp-action="Registrar" class="btn btn-primary">Cadastrar-se</a>
    </div>

    <button class="pub-nav-toggle" id="pub-nav-toggle" aria-label="Menu" aria-expanded="false">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>
</nav>

<!-- ── Conteúdo da página ─────────────────────────────────────────────────── -->
<main class="pub-main">
    @RenderBody()
</main>

<!-- ── Footer ────────────────────────────────────────────────────────────── -->
<footer class="pub-footer">
    <div class="pub-footer-top">
        <div class="pub-footer-brand">
            <a asp-controller="Home" asp-action="Index" class="pub-nav-logo">
                <div class="pub-nav-logo-icon">S</div>
                <span style="color:#fff;">SenacBuy</span>
            </a>
            <p>A plataforma completa para gestão de vendas, clientes e produtos. Simples, segura e eficiente.</p>
        </div>
        <div>
            <p class="pub-footer-col-title">Sistema</p>
            <ul class="pub-footer-links">
                <li><a asp-controller="Home" asp-action="Index">Início</a></li>
                <li><a asp-controller="Home" asp-action="Sobre">Sobre</a></li>
                <li><a asp-controller="Home" asp-action="Contato">Contato</a></li>
            </ul>
        </div>
        <div>
            <p class="pub-footer-col-title">Acesso</p>
            <ul class="pub-footer-links">
                <li><a asp-controller="Account" asp-action="Login">Entrar</a></li>
                <li><a asp-controller="Account" asp-action="Registrar">Criar conta</a></li>
            </ul>
        </div>
        <div>
            <p class="pub-footer-col-title">Recursos</p>
            <ul class="pub-footer-links">
                <li><a href="#">Gestão de Clientes</a></li>
                <li><a href="#">Controle de Produtos</a></li>
                <li><a href="#">Gestão de Pedidos</a></li>
                <li><a href="#">Dashboard</a></li>
            </ul>
        </div>
    </div>
    <div class="pub-footer-bottom">
        <span>&copy; @DateTime.Now.Year SenacBuy — Todos os direitos reservados.</span>
        <div class="pub-footer-bottom-links">
            <a href="#">Privacidade</a>
            <a href="#">Termos de Uso</a>
        </div>
    </div>
</footer>

<script>
// Toggle menu mobile
const toggle = document.getElementById('pub-nav-toggle');
const links  = document.getElementById('pub-nav-links');
toggle?.addEventListener('click', () => {
    const open = links.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open);
});
// Fechar ao clicar fora
document.addEventListener('click', e => {
    if (!toggle?.contains(e.target) && !links?.contains(e.target))
        links?.classList.remove('open');
});
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
