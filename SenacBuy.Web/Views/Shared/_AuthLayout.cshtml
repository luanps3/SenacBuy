<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SenacBuy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --primary:        #137fec;
            --primary-dark:   #0c5db3;
            --primary-light:  #e8f3fd;
            --surface:        #ffffff;
            --bg:             #f0f6fe;
            --text:           #1a2333;
            --text-muted:     #6b7a99;
            --border:         #dce6f5;
            --error:          #dc3545;
            --success:        #28a745;
            --radius:         12px;
            --radius-lg:      20px;
            --shadow:         0 8px 32px rgba(19,127,236,.12);
            --shadow-lg:      0 20px 60px rgba(19,127,236,.18);
            --font:           'Manrope', system-ui, sans-serif;
        }

        body {
            font-family: var(--font);
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: stretch;
        }

        /* ── Layout split-screen ── */
        .auth-shell {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        /* Painel esquerdo — marca */
        .auth-brand {
            flex: 1;
            background: linear-gradient(145deg, #0c5db3 0%, #137fec 55%, #42a0f5 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 2.5rem;
            position: relative;
            overflow: hidden;
        }

        .auth-brand::before {
            content: '';
            position: absolute;
            width: 500px; height: 500px;
            border-radius: 50%;
            background: rgba(255,255,255,.07);
            top: -120px; right: -160px;
        }
        .auth-brand::after {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            border-radius: 50%;
            background: rgba(255,255,255,.05);
            bottom: -80px; left: -80px;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 2.5rem;
            z-index: 1;
        }

        .brand-logo-icon {
            width: 56px; height: 56px;
            border-radius: 14px;
            background: rgba(255,255,255,.25);
            backdrop-filter: blur(8px);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.75rem; font-weight: 800; color: #fff;
            letter-spacing: -1px;
            box-shadow: 0 4px 16px rgba(0,0,0,.15);
        }

        .brand-logo-text {
            font-size: 1.85rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -.5px;
        }

        .brand-tagline {
            font-size: 2rem;
            font-weight: 700;
            color: #fff;
            text-align: center;
            line-height: 1.3;
            z-index: 1;
            margin-bottom: 1rem;
        }

        .brand-sub {
            font-size: .95rem;
            color: rgba(255,255,255,.75);
            text-align: center;
            line-height: 1.6;
            z-index: 1;
            max-width: 320px;
        }

        .brand-dots {
            display: flex;
            gap: 8px;
            margin-top: 2.5rem;
            z-index: 1;
        }

        .brand-dots span {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: rgba(255,255,255,.4);
        }

        .brand-dots span:first-child { background: #fff; width: 24px; border-radius: 4px; }

        /* Painel direito — formulário */
        .auth-form-panel {
            width: 480px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem 3.5rem;
            background: var(--surface);
            overflow-y: auto;
        }

        .auth-form-panel h1 {
            font-size: 1.7rem;
            font-weight: 800;
            color: var(--text);
            margin-bottom: .4rem;
        }

        .auth-form-panel .auth-subtitle {
            font-size: .875rem;
            color: var(--text-muted);
            margin-bottom: 2rem;
        }

        /* Alertas */
        .alert {
            padding: .75rem 1rem;
            border-radius: var(--radius);
            font-size: .875rem;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: flex-start;
            gap: .5rem;
        }
        .alert-danger  { background: #fff2f2; color: var(--error);   border: 1px solid #ffd6d6; }
        .alert-success { background: #f0fff4; color: var(--success);  border: 1px solid #c3e6cb; }

        /* Formulário */
        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-group label {
            display: block;
            font-size: .8rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: .05em;
            margin-bottom: .45rem;
        }

        .form-control {
            width: 100%;
            padding: .8rem 1rem;
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            font-family: var(--font);
            font-size: .95rem;
            color: var(--text);
            background: var(--surface);
            transition: border-color .2s, box-shadow .2s;
            outline: none;
        }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(19,127,236,.12);
        }

        .form-control.input-error { border-color: var(--error); }

        .field-error {
            font-size: .78rem;
            color: var(--error);
            margin-top: .3rem;
        }

        /* Botões */
        .btn-primary {
            width: 100%;
            padding: .9rem;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            border: none;
            border-radius: var(--radius);
            font-family: var(--font);
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: transform .15s, box-shadow .15s, opacity .15s;
            box-shadow: 0 4px 14px rgba(19,127,236,.35);
            margin-bottom: .75rem;
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(19,127,236,.45);
        }

        .btn-primary:active { transform: translateY(0); }

        .btn-secondary {
            width: 100%;
            padding: .85rem;
            background: var(--primary-light);
            color: var(--primary);
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            font-family: var(--font);
            font-size: .95rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s, transform .15s;
            text-decoration: none;
            display: block;
            text-align: center;
        }

        .btn-secondary:hover {
            background: #d8ebfc;
            transform: translateY(-1px);
        }

        /* Divider */
        .auth-divider {
            display: flex;
            align-items: center;
            gap: .75rem;
            margin: .75rem 0;
            color: var(--text-muted);
            font-size: .8rem;
        }
        .auth-divider::before,
        .auth-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        /* Upload foto */
        .file-input-wrapper {
            position: relative;
            border: 2px dashed var(--border);
            border-radius: var(--radius);
            padding: 1.25rem;
            text-align: center;
            cursor: pointer;
            transition: border-color .2s, background .2s;
        }

        .file-input-wrapper:hover {
            border-color: var(--primary);
            background: var(--primary-light);
        }

        .file-input-wrapper input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
        }

        .file-input-text {
            font-size: .875rem;
            color: var(--text-muted);
        }

        .file-input-text strong { color: var(--primary); }

        /* Footer do formulário */
        .auth-footer-link {
            text-align: center;
            font-size: .825rem;
            color: var(--text-muted);
            margin-top: 1.5rem;
        }

        .auth-footer-link a { color: var(--primary); font-weight: 600; text-decoration: none; }
        .auth-footer-link a:hover { text-decoration: underline; }

        /* Responsividade */
        @@media (max-width: 860px) {
            .auth-brand { display: none; }
            .auth-form-panel { width: 100%; padding: 2rem 1.5rem; }
        }
    </style>
</head>
<body>
<div class="auth-shell">

    <!-- Painel da Marca -->
    <div class="auth-brand">
        <div class="brand-logo">
            <div class="brand-logo-icon">S</div>
            <span class="brand-logo-text">SenacBuy</span>
        </div>
        <p class="brand-tagline">Gestão de compras<br />inteligente e eficiente</p>
        <p class="brand-sub">Controle clientes, produtos e pedidos em um só lugar com total segurança.</p>
        <div class="brand-dots">
            <span></span><span></span><span></span>
        </div>
    </div>

    <!-- Painel do Formulário -->
    <div class="auth-form-panel">
        @RenderBody()
    </div>

</div>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
