<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SenacBuy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="app-shell">

    <!-- ── Sidebar ──────────────────────────────────────────────────────── -->
    <aside class="sidebar">
        <a class="sidebar-logo" asp-controller="Dashboard" asp-action="Index">
            <div class="logo-icon">S</div>
            <span class="logo-text">SenacBuy</span>
        </a>

        <span class="sidebar-section">Menu</span>
        <ul class="sidebar-nav">
            <li>
                <a asp-controller="Dashboard" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                        <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                    </svg>
                    Dashboard
                </a>
            </li>
            <li>
                <a asp-controller="Clientes" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Clientes" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    Clientes
                </a>
            </li>
            <li>
                <a asp-controller="Produtos" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Produtos" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                    </svg>
                    Produtos
                </a>
            </li>
            <li>
                <a asp-controller="Pedidos" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Pedidos" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 11l3 3L22 4"/>
                        <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                    </svg>
                    Pedidos
                </a>
            </li>
            <li>
                <a asp-controller="Usuarios" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuarios" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="8" r="4"/>
                        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                    </svg>
                    Usuários
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">© 2026 SenacBuy</div>
    </aside>

    <!-- ── Main Area ─────────────────────────────────────────────────────── -->
    <div class="main-area">

        <!-- Topbar -->
        <header class="topbar">
            <span class="topbar-title">@(ViewData["Title"] ?? "SenacBuy")</span>
            <div class="topbar-right">
                <a class="topbar-user" asp-controller="Usuarios" asp-action="Index">
                    <div class="topbar-avatar">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                        </svg>
                    </div>
                    <span class="topbar-username">Administrador</span>
                </a>
            </div>
        </header>

        <!-- Conteúdo -->
        <main class="page-content">
            @if (TempData["Sucesso"] != null)
            {
                <div class="alert alert-success">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/>
                    </svg>
                    @TempData["Sucesso"]
                </div>
            }
            @RenderBody()
        </main>
    </div>
</div>

<script>
// Confirmação de exclusão
document.querySelectorAll('[data-confirm]').forEach(el => {
    el.addEventListener('click', function(e) {
        if (!confirm(this.dataset.confirm || 'Confirmar ação?')) e.preventDefault();
    });
});
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
